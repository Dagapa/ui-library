		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"oxlint": "^1.71.0",
		"typescript": "~6.0.2",
		"vite": "^8.1.1",
		"vite-plugin-dts": "^4.5.0"
